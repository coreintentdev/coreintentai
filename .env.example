# CoreIntent AI — Environment Configuration
# Copy to .env and fill in your keys

# Claude (Anthropic) — Primary reasoning model
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Grok (xAI) — Fast market analysis, real-time data
XAI_API_KEY=xai-xxxxx
XAI_BASE_URL=https://api.x.ai/v1

# Perplexity — Research and web-grounded intelligence
PERPLEXITY_API_KEY=pplx-xxxxx
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# Model Selection Overrides (optional)
CLAUDE_MODEL=claude-sonnet-4-20250514
GROK_MODEL=grok-3
PERPLEXITY_MODEL=sonar-pro

# Orchestrator Settings
AI_DEFAULT_TIMEOUT_MS=30000
AI_MAX_RETRIES=3
AI_FALLBACK_ENABLED=true

# Logging
AI_LOG_LEVEL=info
AI_LOG_PROMPTS=false
