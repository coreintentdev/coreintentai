{
  "name": "@coreintent/ai",
  "version": "0.1.0",
  "description": "CoreIntent AI Layer — Sovereign multi-model orchestration for algorithmic trading intelligence",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "trading",
    "multi-model",
    "orchestration",
    "sentiment-analysis",
    "claude",
    "grok",
    "perplexity"
  ],
  "author": "Corey McIvor <corey@coreintent.dev>",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.78.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
